---
import DetailLayout from '../layouts/DetailLayout.astro';
---
<DetailLayout title="TimeSpread">
  <section class="site-section" id="section-project-info">
      <div class="container">
        <div class="row mb-5 align-items-center">
          <div class="col-md-6 pr-lg-5 mb-5 mb-lg-0">
            <div class="device-wrapper">
              <div class="device" data-device="Pixel" data-orientation="portrait" data-color="black">
                <div class="screen">
                  <img src="/images/timespread_main.gif" class="sketch-main-img">
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="section-heading">
              <h2><strong>TimeSpread</strong></h2>
            </div>
            <p><span class="date"><span class="icon-calendar"></span> October 2019 - November 2020 </span></p>
            <p class="lead">스마트폰을 사용하지 않은 시간을 리워드로 제공하는 잠금 화면 앱</p>
            <p class="mb-5">DAU 20만 앱의 UsageStatsManager 기반 잠금 화면 및 코인 시스템 개발
              <br>PagerSnapHelper · Lottie 기반 리워드 게임 기능 개발
              <br>Firebase · BigQuery · Android Profiler 기반 앱 품질 관리
              <br>서버 기반 동적 WaterFall 광고 미디에이션 구현
            </p>
              <!-- <a href="#section-contact" class="btn btn-primary px-4 py-2 btn-sm smoothscroll">Go To Market</a> -->
            <a href="https://play.google.com/store/apps/details?id=com.timespread.Timetable2">
              <img src="/images/icons/google_play_badge.png" class="img-fluid google-play-badge">
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="site-section bg-light " id="section-works">
      <div class="container">
        <div class="row">
          <div class="col-md-12 mb-5">
            <div class="section-heading text-center">
              <h2>My <strong>Works</strong></h2>
            </div>
          </div>
          <div class="col-md-12">
            <div class="resume-item mb-4" data-toggle="modal" href="#portfolioModal1">
              <h3>UsageStatsManager 기반 잠금 화면 및 코인 시스템 구현</h3>
              <span class="school">#service #work_manager #broadcast_receiver #usagestatsmanager #room #ad_mediation</span>
            </div>
            <div class="resume-item mb-4" data-toggle="modal" href="#portfolioModal2">
              <h3>PagerSnapHelper · Lottie 기반 리워드 게임 기능 구현</h3>
              <span class="school">#pager_snap_helper #recycler_view #lottie #ad_mediation</span>
            </div>
            <div class="resume-item mb-4" data-toggle="modal" href="#portfolioModal3">
              <h3>Firebase Messaging Service 기반 알림 시스템 구현</h3>
              <span class="school">#firebase_messaging_service #notification</span>
            </div>
            <div class="resume-item mb-4" data-toggle="modal" href="#portfolioModal4">
              <h3>Firebase · BigQuery · Android Profiler 기반 앱 품질 관리</h3>
              <span class="school">#firebase #crashlytics #big_query #android_profiler #leak_canary #hprof</span>
            </div>
            <div class="resume-item mb-4" data-toggle="modal" href="#portfolioModal5">
              <h3>서버 기반 동적 WaterFall 광고 미디에이션 구현</h3>
              <span class="school">#facebook_audience_network #unity #vungle #admob #adfit</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="portfolio-modal modal fade" id="portfolioModal1" tabindex="-1" role="dialog" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="close-modal" data-dismiss="modal">
            <div class="lr">
              <div class="rl"></div>
            </div>
          </div>
          <div class="container">
            <div class="row">
              <div class="col-lg-8 mx-auto">
                <div class="modal-body">
                  <h3>UsageStatsManager 기반 잠금 화면 및 코인 시스템 구현</h3><br>
                  <div id="carouselForModal1" class="carousel slide" data-ride="carousel">
                    <div class="carousel-inner">
                      <div class="carousel-item active">
                        <img class="modal-img" src="/images/screenshots/timespread/lockscreen/1.jpeg">
                      </div>
                      <div class="carousel-item">
                        <img class="modal-img" src="/images/screenshots/timespread/lockscreen/2.jpeg">
                      </div>
                      <div class="carousel-item">
