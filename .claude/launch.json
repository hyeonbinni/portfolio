{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Server (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Live Reload Server (live-server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=8181", "--no-browser"],
      "port": 8181
    }
  ]
}
